{
  "apps": [
    {
      "name": "tempmail_9001",
      "cwd": ".",
      "script": "./src/index.js",
      "interpreter": "node",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "time": true,
      "max_memory_restart": "512M",
      "kill_timeout": 5000,
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}
