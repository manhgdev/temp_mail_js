REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=temp-mail

DOMAINS=tempmail.local,tempinbox.local,tempdrop.local

SMTP_PORT=25
API_PORT=9001

# Set NODE_ENV=production to switch domain source from .env DOMAINS to Firestore.
NODE_ENV=development

# Firebase Admin credentials for backend Firestore access and ID token verification.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Firebase Client config for the /admin login page.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=

# Optional production sweep interval for expired domains.
DOMAIN_EXPIRY_SWEEP_INTERVAL_MS=300000
