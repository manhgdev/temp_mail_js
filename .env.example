# App
NODE_ENV=development
API_PORT=9001
SMTP_PORT=25

# Mail Storage
MAIL_TTL=0
# Keep only the newest N emails per inbox.
MAX_INBOX=50
# Number of emails returned per inbox page by default.
DEFAULT_INBOX_PAGE_SIZE=5

# Redis
# Use REDIS_URL for hosted Redis. If empty, the app falls back to REDIS_HOST/REDIS_PORT.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# S3 / Object Storage
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=temp-mail

# Domains
# In local/dev, active domains are read from DOMAINS.
# In production, active domains are expected to come from Firestore.
DOMAINS=tempmail.local,tempinbox.local,tempdrop.local
DOMAIN_EXPIRY_SWEEP_INTERVAL_MS=300000

# Mail Cache
MAIL_CACHE_PREFIX_VERSION=v1
MAIL_CACHE_INBOX_EXISTS_TTL_SECONDS=60
MAIL_CACHE_INBOX_LIST_TTL_SECONDS=30
MAIL_CACHE_DETAIL_TTL_SECONDS=300

# Firebase Admin
# Required for backend Firestore access and admin ID token verification.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# Firebase Client
# Required for the /admin login page.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=
